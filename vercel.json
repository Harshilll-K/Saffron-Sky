{
  "version": 2,
  "builds": [
    {
      "src": "admin/**/*.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "finalfoody/**/*.php",
      "use": "vercel-php@0.9.0"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "status": 307,
      "headers": {
        "Location": "/finalfoody/homepage.php"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}